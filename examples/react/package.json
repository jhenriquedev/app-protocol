{
  "name": "app-protocol-example-react",
  "version": "0.0.11",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "typecheck": "tsc --noEmit",
    "dev:backend": "tsx watch apps/backend/server.ts",
    "start:backend": "tsx apps/backend/server.ts",
    "dev:portal": "vite --config apps/portal/vite.config.ts",
    "build:portal": "vite build --config apps/portal/vite.config.ts",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
