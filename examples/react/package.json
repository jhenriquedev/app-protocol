{
  "name": "app-protocol-example-react",
  "version": "1.1.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "dev:all": "tsx scripts/dev.ts",
    "dev:http": "tsx scripts/dev.ts",
    "typecheck": "tsc --noEmit",
    "dev:api": "tsx watch apps/backend/server.ts",
    "dev:backend": "tsx watch apps/backend/server.ts",
    "start:api": "tsx apps/backend/server.ts",
    "start:backend": "tsx apps/backend/server.ts",
    "dev:front": "vite --config apps/portal/vite.config.ts",
    "dev:portal": "vite --config apps/portal/vite.config.ts",
    "start:front": "vite --host --config apps/portal/vite.config.ts",
    "start:portal": "vite --host --config apps/portal/vite.config.ts",
    "dev:agent": "tsx watch apps/agent/server.ts",
    "start:agent": "tsx apps/agent/server.ts",
    "dev:agent:mcp": "tsx watch apps/agent/mcp_server.ts",
    "start:agent:mcp": "tsx apps/agent/mcp_server.ts",
    "build:portal": "vite build --config apps/portal/vite.config.ts",
    "smoke": "tsx scripts/smoke.ts && tsx scripts/agentic_smoke.ts && tsx scripts/agent_mcp_smoke.ts && tsx scripts/agent_mcp_http_smoke.ts",
    "smoke:backend": "tsx scripts/smoke.ts",
    "smoke:agentic": "tsx scripts/agentic_smoke.ts",
    "smoke:agent:mcp": "tsx scripts/agent_mcp_smoke.ts",
    "smoke:agent:mcp:http": "tsx scripts/agent_mcp_http_smoke.ts"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
