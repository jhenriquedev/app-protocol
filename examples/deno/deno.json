{
  "nodeModulesDir": "auto",
  "imports": {
    "@std/assert": "jsr:@std/assert@1.0.15",
    "@std/path": "jsr:@std/path@1.1.2",
    "@std/streams/text-line-stream": "jsr:@std/streams@1.0.13/text-line-stream",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@5.0.4",
    "react": "npm:react@19.1.1",
    "react/jsx-runtime": "npm:react@19.1.1/jsx-runtime",
    "react/jsx-dev-runtime": "npm:react@19.1.1/jsx-dev-runtime",
    "react/": "npm:react@19.1.1/",
    "react-dom": "npm:react-dom@19.1.1",
    "react-dom/client": "npm:react-dom@19.1.1/client",
    "react-dom/": "npm:react-dom@19.1.1/",
    "vite": "npm:vite@7.1.9"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "jsxImportSourceTypes": "npm:@types/react@19",
    "lib": [
      "deno.ns",
      "deno.window",
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "strict": true,
    "types": [
      "npm:@types/react@19",
      "npm:@types/react-dom@19"
    ],
    "noImplicitOverride": false,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true
  },
  "tasks": {
    "dev": "deno run --unstable-sloppy-imports -A scripts/dev.ts",
    "dev:all": "deno run --unstable-sloppy-imports -A scripts/dev.ts",
    "dev:http": "deno run --unstable-sloppy-imports -A scripts/dev.ts",
    "typecheck": "deno check --unstable-sloppy-imports apps/backend/server.ts apps/portal/main.tsx apps/agent/server.ts scripts/smoke.ts scripts/agentic_smoke.ts scripts/agent_mcp_smoke.ts scripts/agent_mcp_http_smoke.ts scripts/dev.ts scripts/run_smoke_suite.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "dev:api": "deno run --unstable-sloppy-imports -A --watch apps/backend/server.ts",
    "dev:backend": "deno run --unstable-sloppy-imports -A --watch apps/backend/server.ts",
    "start:api": "deno run --unstable-sloppy-imports -A apps/backend/server.ts",
    "start:backend": "deno run --unstable-sloppy-imports -A apps/backend/server.ts",
    "dev:front": "deno run --unstable-sloppy-imports -A npm:vite --config apps/portal/vite.config.ts",
    "dev:portal": "deno run --unstable-sloppy-imports -A npm:vite --config apps/portal/vite.config.ts",
    "start:front": "deno run --unstable-sloppy-imports -A npm:vite --host --config apps/portal/vite.config.ts",
    "start:portal": "deno run --unstable-sloppy-imports -A npm:vite --host --config apps/portal/vite.config.ts",
    "dev:agent": "deno run --unstable-sloppy-imports -A --watch apps/agent/server.ts",
    "start:agent": "deno run --unstable-sloppy-imports -A apps/agent/server.ts",
    "dev:agent:mcp": "deno run --unstable-sloppy-imports -A --watch apps/agent/mcp_server.ts",
    "start:agent:mcp": "deno run --unstable-sloppy-imports -A apps/agent/mcp_server.ts",
    "build:portal": "deno run --unstable-sloppy-imports -A npm:vite build --config apps/portal/vite.config.ts",
    "smoke": "deno run --unstable-sloppy-imports -A scripts/run_smoke_suite.ts",
    "smoke:backend": "deno run --unstable-sloppy-imports -A scripts/smoke.ts",
    "smoke:agentic": "deno run --unstable-sloppy-imports -A scripts/agentic_smoke.ts",
    "smoke:agent:mcp": "deno run --unstable-sloppy-imports -A scripts/agent_mcp_smoke.ts",
    "smoke:agent:mcp:http": "deno run --unstable-sloppy-imports -A scripts/agent_mcp_http_smoke.ts"
  },
  "exclude": [
    "dist"
  ],
  "lint": {
    "rules": {
      "exclude": [
        "require-await"
      ]
    }
  }
}
